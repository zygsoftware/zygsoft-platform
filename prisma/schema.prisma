generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model ProjectCategory {
  id             String    @id @default(cuid())
  name_tr        String
  name_en        String
  slug           String    @unique
  description_tr String?   @map("descriptionTr")
  description_en String?   @map("descriptionEn")
  created_at     DateTime  @default(now()) @map("createdAt")
  updated_at     DateTime  @updatedAt @map("updatedAt")
  projects       Project[]

  @@map("project_categories")
}

model Project {
  id                     String            @id @default(cuid())
  slug                   String            @unique
  title_tr               String            @map("titleTr")
  title_en               String            @map("titleEn")
  excerpt_tr             String            @map("excerptTr")
  excerpt_en             String            @map("excerptEn")
  content_tr             String            @map("contentTr")
  content_en             String            @map("contentEn")
  category_id             String?           @map("categoryId")
  category               ProjectCategory?  @relation(fields: [category_id], references: [id], onDelete: SetNull)
  sector                 String?
  service_type           String?
  technologies           String?            // JSON array of tech names
  client_name            String?            @map("clientName")
  is_anonymous_client    Boolean           @default(false) @map("isAnonymousClient")
  project_date           DateTime?         @map("projectDate")
  cover_image            String?            @map("coverImage")
  cover_image_alt_tr     String?           @map("coverImageAltTr")
  cover_image_alt_en     String?           @map("coverImageAltEn")
  cover_image_title_tr   String?           @map("coverImageTitleTr")
  cover_image_title_en   String?           @map("coverImageTitleEn")
  cover_image_caption_tr String?           @map("coverImageCaptionTr")
  cover_image_caption_en String?           @map("coverImageCaptionEn")
  problem_tr             String?           @map("problemTr")
  problem_en             String?           @map("problemEn")
  solution_tr            String?           @map("solutionTr")
  solution_en            String?           @map("solutionEn")
  process_tr             String?           @map("processTr")
  process_en             String?           @map("processEn")
  result_tr              String?           @map("resultTr")
  result_en              String?           @map("resultEn")
  metric_label_1_tr      String?           @map("metricLabel1Tr")
  metric_label_1_en      String?           @map("metricLabel1En")
  metric_value_1         String?           @map("metricValue1")
  metric_label_2_tr      String?           @map("metricLabel2Tr")
  metric_label_2_en      String?           @map("metricLabel2En")
  metric_value_2         String?           @map("metricValue2")
  metric_label_3_tr      String?           @map("metricLabel3Tr")
  metric_label_3_en      String?           @map("metricLabel3En")
  metric_value_3         String?           @map("metricValue3")
  live_url               String?           @map("liveUrl")
  demo_url               String?           @map("demoUrl")
  github_url             String?           @map("githubUrl")
  seo_title_tr           String?           @map("seoTitleTr")
  seo_title_en           String?           @map("seoTitleEn")
  seo_description_tr     String?           @map("seoDescriptionTr")
  seo_description_en     String?           @map("seoDescriptionEn")
  seo_keywords_tr        String?           @map("seoKeywordsTr")
  seo_keywords_en        String?           @map("seoKeywordsEn")
  canonical_url           String?           @map("canonicalUrl")
  og_image               String?           @map("ogImage")
  published              Boolean           @default(false)
  featured               Boolean           @default(false) @map("featured")
  sort_order             Int?              @map("sortOrder")
  published_at           DateTime?         @map("publishedAt")
  created_at             DateTime          @default(now()) @map("createdAt")
  updated_at             DateTime          @updatedAt @map("updatedAt")

  @@map("projects")
}

model ApiConnection {
  id        String   @id @default(cuid())
  name      String
  endpoint  String
  apiKey    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  image            String?
  password         String?
  role             String    @default("admin") // admin | staff | customer
  status           String    @default("active") // active | suspended | pending
  phone            String?
  company          String?
  locale           String?   @default("tr")
  notes            String?   // admin-only notes
  lastLoginAt      DateTime? @map("lastLoginAt")
  trialStatus      String    @default("none")
  trialStartedAt  DateTime?
  trialEndsAt      DateTime?
  trialOperationsUsed  Int    @default(0)
  trialOperationsLimit Int    @default(20)
  onboardingCompleted Boolean @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  accounts         Account[]
  sessions         Session[]
  payments         Payment[]
  subscriptions    Subscription[]
  supportTickets   SupportTicket[]
  toolUsages         ToolUsage[]
  letterhead         UserLetterhead?
  blogComments       BlogComment[]
  blogLikes          BlogLike[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  trialStartEvents TrialStartEvent[]
}

model TrialStartEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([source])
}

model UserLetterhead {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filePath  String
  createdAt DateTime @default(now())
}

model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolSlug  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   // bcrypt hash of the token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Payment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  amount       Float
  receiptImage String?
  status       String   @default("pending") // "pending", "approved", "rejected"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  price         Float          @default(0)
  billingPeriod String         @default("yearly") // yearly | monthly
  category      String         @default("legal")  // legal | automation | ai | document
  iconType      String         @default("box")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payments      Payment[]
  subscribers   Subscription[]
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  status      String   @default("inactive") // "inactive", "pending_approval", "active"
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, productId])
}

model BlogCategory {
  id             String    @id @default(cuid())
  name_tr        String
  name_en        String
  slug           String    @unique
  description_tr String?   @map("descriptionTr")
  description_en String?   @map("descriptionEn")
  created_at     DateTime  @default(now()) @map("createdAt")
  updated_at     DateTime  @default(now()) @updatedAt @map("updatedAt")
  posts          BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id    String        @id @default(cuid())
  name  String
  slug  String        @unique
  posts BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  post_id String   @map("postId")
  tag_id  String   @map("tagId")
  post    BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag     BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
  @@map("blog_post_tags")
}

model BlogPost {
  id                     String        @id @default(cuid())
  slug                   String        @unique
  title_tr               String        @map("titleTr")
  title_en               String        @map("titleEn")
  excerpt_tr             String        @map("excerptTr")
  excerpt_en             String        @map("excerptEn")
  content_tr             String        @map("contentTr")
  content_en             String        @map("contentEn")
  cover_image            String?       @map("coverImage")
  cover_image_alt_tr     String?       @map("coverImageAltTr")
  cover_image_alt_en     String?       @map("coverImageAltEn")
  cover_image_title_tr   String?       @map("coverImageTitleTr")
  cover_image_title_en   String?       @map("coverImageTitleEn")
  cover_image_caption_tr String?       @map("coverImageCaptionTr")
  cover_image_caption_en String?       @map("coverImageCaptionEn")
  seo_title_tr           String?       @map("seoTitleTr")
  seo_title_en       String?       @map("seoTitleEn")
  seo_description_tr String?       @map("seoDescriptionTr")
  seo_description_en String?       @map("seoDescriptionEn")
  seo_keywords_tr    String?       @map("seoKeywordsTr")
  seo_keywords_en    String?       @map("seoKeywordsEn")
  og_image           String?       @map("ogImage")
  canonical_url      String?       @map("canonicalUrl")
  category_id        String?       @map("categoryId")
  category           BlogCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  is_featured        Boolean       @default(false) @map("isFeatured")
  published          Boolean       @default(false)
  allow_comments     Boolean       @default(true) @map("allowComments")
  view_count         Int           @default(0) @map("viewCount")
  author             String        @default("ZYGSOFT")
  published_at       DateTime?     @map("publishedAt")
  reading_time_min   Int?          @map("readingTimeMin")
  created_at         DateTime      @default(now()) @map("createdAt")
  updated_at         DateTime      @updatedAt @map("updatedAt")
  tags               BlogPostTag[]
  comments           BlogComment[]
  likes              BlogLike[]

  @@map("blog_posts")
}

model BlogComment {
  id        String    @id @default(cuid())
  post_id   String    @map("postId")
  post      BlogPost  @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user_id   String?   @map("userId")
  user      User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)
  name      String?
  email     String?
  content   String
  status    String    @default("pending") // pending | approved | rejected
  parent_id String?   @map("parentId")
  parent    BlogComment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  created_at DateTime @default(now()) @map("createdAt")
  updated_at DateTime @updatedAt @map("updatedAt")

  @@map("blog_comments")
}

model BlogLike {
  id        String   @id @default(cuid())
  post_id   String   @map("postId")
  post      BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user_id   String   @map("userId")
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now()) @map("createdAt")

  @@unique([post_id, user_id])
  @@map("blog_likes")
}
model SupportTicket {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  subject        String
  message        String
  status         String    @default("open") // "open" | "in_progress" | "answered" | "closed"
  ticketCode     String?   @unique
  adminReply     String?
  lastRepliedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new") // "new" | "read" | "archived"
  adminNote String?
  createdAt DateTime @default(now())
}
